# Copy to apps/api/.env and apps/web/.env.local as needed
DATABASE_URL="postgresql://assetflow:assetflow@localhost:5432/assetflow?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"
AUTH_EXPOSE_RESET_TOKEN="true"
API_PORT=4000
API_CORS_ORIGIN="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# Cloudinary (replace with production values later)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_FOLDER="assetflow"

MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="assetflow"
MINIO_SECRET_KEY="assetflowsecret"
MINIO_BUCKET="assetflow"
