{
  "name": "assetflow",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@assetflow/web",
    "dev:api": "turbo run dev --filter=@assetflow/api",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@assetflow/api",
    "db:migrate": "turbo run db:migrate --filter=@assetflow/api",
    "db:seed": "turbo run db:seed --filter=@assetflow/api",
    "db:check": "pnpm --filter @assetflow/api db:check",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:logs": "docker compose -f infra/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  }
}
